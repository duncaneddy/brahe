{
  "name": "brahe-wasm",
  "version": "1.5.1",
  "description": "WebAssembly bindings for the brahe astrodynamics library",
  "license": "MIT",
  "homepage": "https://duncaneddy.github.io/brahe/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/duncaneddy/brahe.git",
    "directory": "crates/brahe-wasm"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "imports": {
    "#wasm": {
      "node": "./pkg-node/brahe_wasm.js",
      "default": "./pkg-bundler/brahe_wasm.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "pkg-bundler",
    "pkg-node",
    "README.md"
  ],
  "scripts": {
    "build:wasm:bundler": "wasm-pack build --target bundler --out-dir pkg-bundler",
    "build:wasm:node": "wasm-pack build --target nodejs --out-dir pkg-node",
    "build:wasm": "npm run build:wasm:bundler && npm run build:wasm:node",
    "build:ts": "tsc",
    "build": "npm run build:wasm && npm run build:ts",
    "test": "npm run build && vitest run",
    "docs": "typedoc"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.2.0",
    "typescript": "^5.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^2.1.0"
  }
}
